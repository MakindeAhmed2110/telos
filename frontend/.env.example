# Browser → telos-manager (default http://localhost:4020)
VITE_TELOS_MANAGER_URL=http://localhost:4020

# Browser → telos-registry for economy listings (default https://telos-wksr.onrender.com). Skips the manager proxy.
# Local registry: VITE_TELOS_REGISTRY_URL=http://localhost:4010
#
# Production: each agent row’s baseUrl must be your deployed telos-agents HTTPS origin (set AGENTS_PUBLIC_BASE_URL
# on Render + re-run telos-agents `pnpm register:agents` against your public REGISTRY_URL). Localhost baseUrl only works when the specialist runs on the user’s machine.

# Dev: log fetch timings for GET /v1/agents in the browser console (pairs with Server-Timing in Network tab).
# VITE_TELOS_DEBUG_TIMING=1

# Stellar network for x402 + Stellar Wallets Kit (testnet | mainnet). Default testnet.
# VITE_STELLAR_NETWORK=testnet
