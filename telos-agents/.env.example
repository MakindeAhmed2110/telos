PORT=3100

# Populate telos-registry so the frontend Economy page lists agents (GET /v1/agents):
#   1. Run telos-registry (pnpm dev, default :4010)
#   2. Set REGISTRY_URL + AGENTS_PUBLIC_BASE_URL + PAY_TO_* below, then: pnpm register:agents
REGISTRY_URL=http://localhost:4010
AGENTS_PUBLIC_BASE_URL=http://localhost:3100

# --- Production (e.g. Render): telos-agents and telos-registry public HTTPS URLs ---
# Must match the URL browsers and telos-manager use to reach this service (no trailing slash).
# REGISTRY_URL=https://your-registry.onrender.com
# AGENTS_PUBLIC_BASE_URL=https://your-telos-agents.onrender.com
# Then run from your machine: pnpm register:agents (script refuses localhost baseUrl against a remote registry)

# Default fallback if a PAY_TO_* below is omitted (single-merchant mode only)
TESTNET_SERVER_STELLAR_ADDRESS=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Separate agents: set one address per route; each must match that agent's `payTo` in telos-registry ---
# Suggested registry ids: weather-oracle, mathsolver, summarizer-pro, crypto-sentiment, deepresearchai, market-oracle, website-builder
# Same baseUrl for all (e.g. http://localhost:3100), different payTo + capabilities per row.
PAY_TO_WEATHER=G...
PAY_TO_MATH=G...
PAY_TO_SUMMARIZE=G...
PAY_TO_CRYPTO_SENTIMENT=G...
PAY_TO_DEEP_RESEARCH=G...
PAY_TO_MARKET=G...
PAY_TO_WEBSITE_BUILDER=G...

# Fail startup unless all PAY_TO_* above are set (recommended for your multi-agent demo)
REQUIRE_SEPARATE_AGENT_PAY_TO=true

# Facilitator base URL only (no /supported suffix; trailing slashes are stripped). e.g. https://telos-facilitator.onrender.com
TESTNET_FACILITATOR_URL=http://localhost:4022
# TESTNET_FACILITATOR_API_KEY=

TESTNET_STELLAR_RPC_URL=https://soroban-testnet.stellar.org

PAYMENT_PRICE=0.01

# Agent-to-agent: treasury pays downstream x402 agents (fund + USDC trustline)
# AGENT_HIRING_STELLAR_SECRET=S...
# AGENT_HIRING_NETWORK=testnet

# Origins the hiring wallet may call (comma-separated). If unset, defaults to this host + HIRE_DEEP_RESEARCH_URL host.
# HIRING_ALLOWED_ORIGINS=http://localhost:3100,https://partner-agent.example

# Optional: external deep-research URL (POST JSON { "prompt" }). Default: {AGENTS_PUBLIC_BASE_URL}/deep-research/testnet
# HIRE_DEEP_RESEARCH_URL=https://their-host/v1/research

# PAYWALL_DISABLED=false

# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini
# Stronger model for POST /deep-research/testnet (defaults to OPENROUTER_MODEL)
# DEEP_RESEARCH_MODEL=anthropic/claude-3.5-sonnet
# Model for POST /website-builder/testnet (defaults to OPENROUTER_MODEL)
# WEBSITE_BUILDER_MODEL=openai/gpt-4o-mini

# CoinGecko: live USD for GET /market/testnet?symbol=BTC (Demo API: api.coingecko.com + x-cg-demo-api-key)
# Also powers POST /crypto-sentiment/testnet (market + community vote %)
# COINGECKO_API_KEY=
# Use Pro base URL + x-cg-pro-api-key when true
# COINGECKO_PRO=false
